func _make_strike(
	p_move_name: String,
	p_move_type: MoveResource.MoveType,
	p_class_preferrence: Array[WrestlerResource.WrestlerClass],
	p_move_target_parts: Array[MoveResource.MoveTargetParts],
	p_required_attacker_position: WrestlerResource.Position,
	p_required_target_position: WrestlerResource.Position,
	p_resulting_attacker_position: WrestlerResource.Position,
	p_resulting_target_position: WrestlerResource.Position,
	p_strike_weight: MoveResource.StrikeWeight,
	p_is_finisher: bool,
	p_move_impact: int
) -> MoveResource:
	return _make_move(
		p_move_name,
		p_move_type,
		p_class_preferrence,
		p_move_target_parts,
		p_required_attacker_position,
		p_required_target_position,
		p_resulting_attacker_position,
		p_resulting_target_position,
		p_is_finisher,
		false,
		true,
		p_move_impact,
		p_strike_weight
	)

