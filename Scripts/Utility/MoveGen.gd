
@tool
extends EditorScript
class_name MoveFactory

const MOVE_ROOT: String = "res://Moves/"
const BOTH_ARM_MOVES: Array[String] = [
	"Avalanche Butterfly Suplex", "Butterfly Suplex", "Cattle Mutilation",
	"Double Underhook Facebuster", "Double Underhook Suplex", "Full Nelson Bomb",
	"Full Nelson Slam", "Rings of Saturn", "Straight Jacket Hold",
	"Surfboard Stretch", "Tiger Plex", "Tiger Suplex",
]
const BOTH_LEG_MOVES: Array[String] = [
	"Boston Crab", "Cloverleaf", "Figure Four Leglock", "Indian Deathlock",
	"Muta Lock", "Package Piledriver", "Scorpion Deathlock", "Sharpshooter",
	"Sharpshooter Hold", "Texas Cloverleaf",
]

func _run() -> void:
	var moves: Array[MoveResource] = _build_all_moves()

	if moves.is_empty():
		push_warning("No moves were built.")
		return

	for move: MoveResource in moves:
		if move == null:
			push_warning("Null move encountered, skipping.")
			continue

		var save_dir: String = _get_save_dir(move)
		if save_dir.is_empty():
			push_warning("Unsupported routing for move: %s" % move.move_name)
			continue

		_ensure_dir(save_dir)

		var file_name: String = _sanitize_file_name(move.move_name) + ".tres"
		var save_path: String = save_dir + file_name

		var result: Error = ResourceSaver.save(move, save_path)
		if result != OK:
			push_error("Failed to save move '%s' to %s. Error code: %s" % [move.move_name, save_path, str(result)])
		else:
			print("Saved: ", save_path)

	print("Move export complete.")

func _build_all_moves() -> Array[MoveResource]:
	var moves: Array[MoveResource] = []
	moves.append_array(_build_standing_front_moves())
	moves.append_array(_build_standing_behind_moves())
	moves.append_array(_build_running_moves())
	moves.append_array(_build_rope_rebound_moves())
	moves.append_array(_build_grounded_moves())
	moves.append_array(_build_grounded_finishers())
	moves.append_array(_build_submission_moves())
	moves.append_array(_build_springboard_moves())
	moves.append_array(_build_corner_moves())
	moves.append_array(_build_diving_standing_moves())
	moves.append_array(_build_diving_grounded_moves())
	moves.append_array(_build_weak_strikes())
	moves.append_array(_build_medium_strikes())
	moves.append_array(_build_heavy_strikes())
	moves.append_array(_build_heavy_strike_finishers())
	return moves

func _build_move_array_from_specs(move_type: MoveResource.MoveType, specs: Array) -> Array[MoveResource]:
	var moves: Array[MoveResource] = []
	for spec_variant in specs:
		var spec: Dictionary = spec_variant

		var typed_classes: Array[WrestlerResource.WrestlerClass] = []
		for c in spec["classes"]:
			typed_classes.append(c)

		var typed_parts: Array[MoveResource.MoveTargetParts] = []
		for p in spec["parts"]:
			typed_parts.append(p)

		moves.append(_make_move(
			spec["name"],
			move_type,
			typed_classes,
			typed_parts,
			spec["req_attacker"],
			spec["req_target"],
			spec["res_attacker"],
			spec["res_target"],
			spec["finisher"],
			spec["submission"],
			false,
			spec["impact"]
		))
	return moves

func _get_base_path_for_move_type(move_type: MoveResource.MoveType) -> String:
	match move_type:
		MoveResource.MoveType.STANDING_FRONT:
			return MOVE_ROOT + "Standing_Front/"
		MoveResource.MoveType.STANDING_BEHIND:
			return MOVE_ROOT + "Standing_Behind/"
		MoveResource.MoveType.RUNNING:
			return MOVE_ROOT + "Running/"
		MoveResource.MoveType.ROPE_REBOUND:
			return MOVE_ROOT + "Rope_Rebound/"
		MoveResource.MoveType.GROUNDED:
			return MOVE_ROOT + "Grounded/"
		MoveResource.MoveType.SPRINGBOARD:
			return MOVE_ROOT + "Springboard/"
		MoveResource.MoveType.CORNER:
			return MOVE_ROOT + "Corner/"
		MoveResource.MoveType.DIVING_STANDING:
			return MOVE_ROOT + "Diving_Standing/"
		MoveResource.MoveType.DIVING_GROUNDED:
			return MOVE_ROOT + "Diving_Grounded/"
		_:
			return ""


func _get_save_dir(move: MoveResource) -> String:
	if move.is_submission:
		return MOVE_ROOT + "Submissions/Finishers/" if move.is_finisher else MOVE_ROOT + "Submissions/"

	if move.is_strike:
		match move.strike_weight:
			MoveResource.StrikeWeight.STRIKE_WEAK:
				return MOVE_ROOT + "Strikes/Weak/"
			MoveResource.StrikeWeight.STRIKE_MEDIUM:
				return MOVE_ROOT + "Strikes/Medium/"
			MoveResource.StrikeWeight.STRIKE_HEAVY:
				return MOVE_ROOT + "Strikes/Heavy/Finishers/" if move.is_finisher else MOVE_ROOT + "Strikes/Heavy/"
			_:
				return MOVE_ROOT + "Strikes/Weak/"

	var base_path: String = _get_base_path_for_move_type(move.move_type)
	if base_path.is_empty():
		return ""

	return base_path + "Finishers/" if move.is_finisher else base_path

func _ensure_dir(path: String) -> void:
	var dir := DirAccess.open("res://")
	if dir == null:
		push_error("Could not open res://")
		return

	var trimmed: String = path.trim_prefix("res://").trim_suffix("/")
	if trimmed.is_empty():
		return

	var parts: PackedStringArray = trimmed.split("/")
	var current_path: String = "res://"

	for part: String in parts:
		current_path += part
		if not DirAccess.dir_exists_absolute(current_path):
			var make_result: Error = DirAccess.make_dir_absolute(current_path)
			if make_result != OK and make_result != ERR_ALREADY_EXISTS:
				push_error("Failed to create directory: %s" % current_path)
				return
		current_path += "/"

func _sanitize_file_name(name: String) -> String:
	var file_name: String = name.to_lower()
	file_name = file_name.replace(" ", "_")
	file_name = file_name.replace("-", "_")
	file_name = file_name.replace("'", "")
	file_name = file_name.replace("\"", "")
	file_name = file_name.replace(".", "")
	file_name = file_name.replace(",", "")
	file_name = file_name.replace("!", "")
	file_name = file_name.replace("?", "")
	file_name = file_name.replace(":", "")
	file_name = file_name.replace(";", "")
	file_name = file_name.replace("/", "_")
	file_name = file_name.replace("\\", "_")
	file_name = file_name.replace("(", "")
	file_name = file_name.replace(")", "")
	file_name = file_name.replace("&", "and")
	file_name = file_name.replace("á", "a")
	file_name = file_name.replace("é", "e")
	file_name = file_name.replace("í", "i")
	file_name = file_name.replace("ó", "o")
	file_name = file_name.replace("ú", "u")
	file_name = file_name.replace("ñ", "n")
	return file_name

func _make_move(
	p_move_name: String,
	p_move_type: MoveResource.MoveType,
	p_class_preferrence: Array[WrestlerResource.WrestlerClass],
	p_move_target_parts: Array[MoveResource.MoveTargetParts],
	p_required_attacker_position: WrestlerResource.Position,
	p_required_target_position: WrestlerResource.Position,
	p_resulting_attacker_position: WrestlerResource.Position,
	p_resulting_target_position: WrestlerResource.Position,
	p_is_finisher: bool,
	p_is_submission: bool,
	p_is_strike: bool,
	p_move_impact: int,
	p_strike_weight: MoveResource.StrikeWeight = MoveResource.StrikeWeight.STRIKE_WEAK
) -> MoveResource:
	var move: MoveResource = MoveResource.new()
	move.move_name = p_move_name
	move.move_type = p_move_type
	move.class_preferrence = p_class_preferrence
	move.move_target_parts = p_move_target_parts
	move.targeting_mode = _targeting_mode_for(p_move_name, p_move_target_parts)
	if move.targeting_mode == MoveResource.TargetingMode.CHOOSE_ARM:
		move.default_side_target = MoveResource.MoveTargetParts.LEFT_ARM
	elif move.targeting_mode == MoveResource.TargetingMode.CHOOSE_LEG:
		move.default_side_target = MoveResource.MoveTargetParts.LEFT_LEG
	move.required_attacker_position = p_required_attacker_position
	move.required_target_position = p_required_target_position
	move.resulting_attacker_position = p_resulting_attacker_position
	move.resulting_target_position = p_resulting_target_position
	move.is_finisher = p_is_finisher
	move.is_submission = p_is_submission
	move.is_strike = p_is_strike
	if p_is_strike:
		move.strike_weight = p_strike_weight
	move.move_impact = p_move_impact
	return move


func _targeting_mode_for(move_name: String, parts: Array[MoveResource.MoveTargetParts]) -> int:
	if move_name == "Bow and Arrow Hold":
		return MoveResource.TargetingMode.FIXED_PARTS
	if move_name in BOTH_ARM_MOVES:
		return MoveResource.TargetingMode.BOTH_ARMS
	if move_name in BOTH_LEG_MOVES:
		return MoveResource.TargetingMode.BOTH_LEGS
	var has_both_arms := (
		MoveResource.MoveTargetParts.LEFT_ARM in parts
		and MoveResource.MoveTargetParts.RIGHT_ARM in parts
	)
	var has_both_legs := (
		MoveResource.MoveTargetParts.LEFT_LEG in parts
		and MoveResource.MoveTargetParts.RIGHT_LEG in parts
	)
	if has_both_arms:
		return MoveResource.TargetingMode.CHOOSE_ARM
	if has_both_legs:
		return MoveResource.TargetingMode.CHOOSE_LEG
	return MoveResource.TargetingMode.FIXED_PARTS

